{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/route-to-agent.sh"
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "matcher": "plugin-lights|qol-plugin-lights:plugin-lights",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/reflect-agent.sh"
                    }
                ]
            }
        ]
    }
}
