{
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/route-to-agent.sh"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/commit-skill-context.sh"
                    },
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/commit-deny-coauthor.sh"
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "matcher": "qol-tray-frontend|qol-tray-backend",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/reflect-agent.sh"
                    }
                ]
            }
        ]
    }
}
