{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup|resume|clear",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/inject-dev-recompile-context.cjs"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write|NotebookEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/route-to-agent.cjs"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commit-skill-context.cjs"
                    },
                    {
                        "type": "command",
                        "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/commit-deny-coauthor.cjs"
                    }
                ]
            }
        ],
        "SubagentStop": [
            {
                "matcher": "qol-tray-frontend|qol-tray-backend",
                "hooks": [
                    {
                        "type": "command",
                        "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/reflect-agent.cjs"
                    }
                ]
            }
        ]
    }
}
